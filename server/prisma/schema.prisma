generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GlobalSettings {
  id                     Int      @id @default(autoincrement())
  facebookUrl            String?
  instagramUrl           String?
  whatsappUrl            String?
  websiteUrl             String?
  contactPhone           String?
  contactEmail           String?
  platformPaystackKey    String?
  platformFlutterwaveKey String?
  platformSecretKey      String?
  s3AccessKey            String?
  s3SecretKey            String?
  s3BucketName           String?
  s3Region               String?  @default("us-east-1")
  enableAutoBackup       Boolean  @default(false)
  backupRetentionDays    Int      @default(30)
  basicPrice             Float    @default(50000)
  standardPrice          Float    @default(120000)
  premiumPrice           Float    @default(250000)
  updatedAt              DateTime @updatedAt
  apkDownloadUrl         String?
  latestAppVersion       String?  @default("1.0.0")
  geminiApiKey           String?
  groqApiKey             String?
  whatsappProvider       String?  @default("twilio")
  metaAccessToken        String?
  metaBusinessAccountId  String?
  metaPhoneNumberId      String?
  metaVerifyToken        String?
  twilioAccountSid       String?
  twilioAuthToken        String?
  whatsappPhoneNumber    String?
}

model School {
  id                          Int                       @id @default(autoincrement())
  slug                        String                    @unique
  code                        String?                   @unique
  customDomain                String?                   @unique
  name                        String
  address                     String?
  phone                       String?
  email                       String?
  motto                       String?
  logoUrl                     String?
  principalSignatureUrl       String?
  openingHours                String?                   @default("Mon - Fri: 8:00 AM - 4:00 PM")
  welcomeTitle                String?                   @default("Building a Brighter Future Together")
  welcomeMessage              String?                   @default("Providing a supportive and innovative environment where every student can achieve their full potential and prepare for success in an ever-changing world.")
  primaryColor                String                    @default("#1e40af")
  secondaryColor              String                    @default("#3b82f6")
  accentColor                 String                    @default("#60a5fa")
  paystackPublicKey           String?
  paystackSecretKey           String?
  flutterwavePublicKey        String?
  flutterwaveSecretKey        String?
  enableOnlinePayment         Boolean                   @default(false)
  emailUser                   String?
  emailPassword               String?
  emailHost                   String?
  emailPort                   Int?                      @default(465)
  emailSecure                 Boolean                   @default(true)
  smsUsername                 String?
  smsApiKey                   String?
  smsSenderId                 String?
  enableSMS                   Boolean                   @default(false)
  whatsappBotEnabled          Boolean                   @default(false)
  whatsappProvider            String?                   @default("twilio")
  whatsappPhoneNumber         String?
  twilioAccountSid            String?
  twilioAuthToken             String?
  metaAccessToken             String?
  metaPhoneNumberId           String?
  metaBusinessAccountId       String?
  metaVerifyToken             String?
  geminiApiKey                String?
  groqApiKey                  String?
  facebookUrl                 String?
  instagramUrl                String?
  whatsappUrl                 String?
  academicCalendarUrl         String?
  eLibraryUrl                 String?
  alumniNetworkUrl            String?
  brochureFileUrl             String?
  admissionGuideFileUrl       String?
  licenseKey                  String?                   @unique
  isActivated                 Boolean                   @default(false)
  packageType                 String?                   @default("basic")
  maxStudents                 Int?                      @default(500)
  expiresAt                   DateTime?
  subscriptionActive          Boolean                   @default(true)
  lastBillingDate             DateTime?
  nextBillingDate             DateTime?
  assignment1Weight           Int                       @default(5)
  assignment2Weight           Int                       @default(5)
  test1Weight                 Int                       @default(10)
  test2Weight                 Int                       @default(10)
  examWeight                  Int                       @default(70)
  examMode                    Boolean                   @default(false)
  examModeType                String                    @default("none")
  isSetupComplete             Boolean                   @default(false)
  staffExpectedArrivalTime    String?                   @default("07:00")
  staffClockInDeadline        String?                   @default("10:00")
  enableStaffAttendanceReport Boolean                   @default(true)
  staffClockInMode            String?                   @default("anywhere")
  authorizedIP                String?
  gradingSystem               String?                   @default("[{\"grade\":\"A\",\"min\":70,\"max\":100,\"remark\":\"Excellent\"},{\"grade\":\"B\",\"min\":60,\"max\":69.9,\"remark\":\"Very Good\"},{\"grade\":\"C\",\"min\":50,\"max\":59.9,\"remark\":\"Good\"},{\"grade\":\"D\",\"min\":40,\"max\":49.9,\"remark\":\"Pass\"},{\"grade\":\"E\",\"min\":30,\"max\":39.9,\"remark\":\"Weak Pass\"},{\"grade\":\"F\",\"min\":0,\"max\":29.9,\"remark\":\"Fail\"}]")
  passThreshold               Int                       @default(40)
  weekendDays                 String?
  reportFontFamily            String?                   @default("serif")
  reportColorScheme           String?                   @default("")
  showPositionOnReport        Boolean                   @default(true)
  showFeesOnReport            Boolean                   @default(true)
  showAttendanceOnReport      Boolean                   @default(true)
  showPassFailStats           Boolean                   @default(true)
  reportLayout                String?                   @default("classic")
  certFontFamily              String?                   @default("serif")
  certBorderType              String?                   @default("ornate")
  certPrimaryColor            String?                   @default("")
  certSecondaryColor          String?                   @default("")
  testimFontFamily            String?                   @default("sans-serif")
  testimBorderType            String?                   @default("modern")
  testimPrimaryColor          String?                   @default("")
  testimSecondaryColor        String?                   @default("")
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  academicSessions            AcademicSession[]
  alumni                      Alumni[]
  AlumniDonation              AlumniDonation[]
  AlumniEvent                 AlumniEvent[]
  AlumniStory                 AlumniStory[]
  attendanceRecords           AttendanceRecord[]
  auditLogs                   AuditLog[]
  CBTExam                     CBTExam[]
  CBTQuestion                 CBTQuestion[]
  CBTQuestionBank             CBTQuestionBank[]
  CBTResult                   CBTResult[]
  certificates                Certificate[]
  classes                     Class[]
  ClassFeeStructure           ClassFeeStructure[]
  classSubjects               ClassSubject[]
  counters                    Counter[]
  curriculums                 Curriculum[]
  departments                 Department[]
  examCards                   ExamCard[]
  examRepository              ExamRepository[]
  FeePayment                  FeePayment[]
  FeeRecord                   FeeRecord[]
  GalleryImage                GalleryImage[]
  Homework                    Homework[]
  HomeworkSubmission          HomeworkSubmission[]
  interventions               Intervention[]
  LearningResource            LearningResource[]
  lessonNotes                 LessonNote[]
  lessonPlans                 LessonPlan[]
  MiscellaneousFee            MiscellaneousFee[]
  MiscellaneousFeePayment     MiscellaneousFeePayment[]
  newsEvents                  NewsEvent[]
  notices                     Notice[]
  OnlinePayment               OnlinePayment[]
  Parent                      Parent[]
  ParentTeacherMessage        ParentTeacherMessage[]
  promotionHistory            PromotionHistory[]
  PsychomotorDomain           PsychomotorDomain[]
  quranRecords                QuranRecord[]
  quranTargets                QuranTarget[]
  results                     Result[]
  resultPublications          ResultPublication[]
  schoolHolidays              SchoolHoliday[]
  staffAttendance             StaffAttendance[]
  students                    Student[]
  studentReportCards          StudentReportCard[]
  subjects                    Subject[]
  teachers                    Teacher[]
  assignments                 TeacherAssignment[]
  teacherAvailabilities       TeacherAvailability[]
  terms                       Term[]
  testimonials                Testimonial[]
  timetables                  Timetable[]
  users                       User[]
  WhatsAppLog                 WhatsAppLog[]
}

model User {
  id                 Int                  @id @default(autoincrement())
  schoolId           Int?
  username           String
  passwordHash       String
  email              String?
  phone              String?
  role               String
  firstName          String
  lastName           String
  photoUrl           String?
  signatureUrl       String?
  isActive           Boolean              @default(true)
  mustChangePassword Boolean              @default(false)
  createdAt          DateTime             @default(now())
  departmentId       Int?
  CBTExam            CBTExam[]
  CBTQuestionBank    CBTQuestionBank[]
  certificatesIssued Certificate[]        @relation("CertificateIssuer")
  classesAsTeacher   Class[]              @relation("ClassTeacher")
  departmentAsHead   Department?          @relation("DepartmentHead")
  createdExams       ExamRepository[]
  FeePayment         FeePayment[]
  FeeRecord          FeeRecord[]
  GalleryImage       GalleryImage[]
  Homework           Homework[]
  HomeworkSubmission HomeworkSubmission[]
  interventions      Intervention[]
  LearningResource   LearningResource[]
  lessonNotes        LessonNote[]
  lessonPlans        LessonPlan[]
  NewsEvent          NewsEvent[]
  notices            Notice[]             @relation("NoticeAuthor")
  receivedNudges     Nudge[]              @relation("NudgeReceiver")
  sentNudges         Nudge[]              @relation("NudgeSender")
  Parent             Parent?
  quranRecords       QuranRecord[]        @relation("QuranTeacher")
  verifiedAttendance StaffAttendance[]    @relation("AttendanceVerifier")
  staffAttendance    StaffAttendance[]    @relation("StaffUser")
  student            Student?
  teacher            Teacher?
  assignments        TeacherAssignment[]
  testimonialsIssued Testimonial[]        @relation("TestimonialIssuer")
  department         Department?          @relation("DepartmentStaff", fields: [departmentId], references: [id])
  school             School?              @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, username])
  @@unique([schoolId, email])
  @@index([email])
  @@index([username])
}

model Student {
  id                      Int                       @id @default(autoincrement())
  schoolId                Int
  userId                  Int?                      @unique
  parentId                Int?
  admissionNumber         String
  classId                 Int?
  dateOfBirth             DateTime?
  gender                  String?
  stateOfOrigin           String?
  nationality             String?                   @default("Nigerian")
  address                 String?
  photoUrl                String?
  parentGuardianName      String?
  parentGuardianPhone     String?
  parentEmail             String?
  bloodGroup              String?
  genotype                String?
  disability              String?
  name                    String?
  rollNo                  String?
  class                   String?
  parentPhone             String?
  createdAt               DateTime                  @default(now())
  middleName              String?
  status                  String                    @default("active")
  clubs                   String?
  isScholarship           Boolean                   @default(false)
  isExamRestricted        Boolean                   @default(false)
  examRestrictionReason   String?
  alumniProfile           Alumni?
  attendanceRecords       AttendanceRecord[]
  CBTResult               CBTResult[]
  certificate             Certificate?
  examCards               ExamCard[]
  FeeRecord               FeeRecord[]
  homeworkSubmissions     HomeworkSubmission[]
  interventions           Intervention[]
  MiscellaneousFeePayment MiscellaneousFeePayment[]
  OnlinePayment           OnlinePayment[]
  promotionHistory        PromotionHistory[]
  quranRecords            QuranRecord[]
  results                 Result[]
  user                    User?                     @relation(fields: [userId], references: [id])
  parent                  Parent?                   @relation("StudentParent", fields: [parentId], references: [id])
  classModel              Class?                    @relation(fields: [classId], references: [id])
  school                  School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  reportCards             StudentReportCard[]
  testimonial             Testimonial?

  @@unique([schoolId, admissionNumber])
  @@unique([schoolId, rollNo])
  @@index([schoolId, classId])
  @@index([admissionNumber])
}

model Teacher {
  id             Int                   @id @default(autoincrement())
  schoolId       Int
  userId         Int                   @unique
  staffId        String
  specialization String?
  createdAt      DateTime              @default(now())
  photoUrl       String?
  publicEmail    String?
  publicPhone    String?
  publicWhatsapp String?
  user           User                  @relation(fields: [userId], references: [id])
  school         School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  availabilities TeacherAvailability[]

  @@unique([schoolId, staffId])
  @@index([staffId])
}

model TeacherAvailability {
  id          Int     @id @default(autoincrement())
  schoolId    Int
  teacherId   Int
  dayOfWeek   String
  startTime   String?
  endTime     String?
  isAvailable Boolean @default(false)
  teacher     Teacher @relation(fields: [teacherId], references: [id])
  school      School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, teacherId])
}

model Subject {
  id               Int                @id @default(autoincrement())
  schoolId         Int
  name             String
  code             String?
  createdAt        DateTime           @default(now())
  departmentId     Int?
  CBTExam          CBTExam[]
  CBTQuestionBank  CBTQuestionBank[]
  classes          ClassSubject[]
  curriculums      Curriculum[]
  examRepo         ExamRepository[]
  Homework         Homework[]
  LearningResource LearningResource[]
  lessonNotes      LessonNote[]
  lessonPlans      LessonPlan[]
  quranRecords     QuranRecord[]
  quranTargets     QuranTarget[]
  results          Result[]
  department       Department?        @relation(fields: [departmentId], references: [id])
  school           School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  timetables       Timetable[]

  @@unique([schoolId, code])
}

model Class {
  id                     Int                 @id @default(autoincrement())
  schoolId               Int
  name                   String
  arm                    String?
  classTeacherId         Int?
  isActive               Boolean             @default(true)
  createdAt              DateTime            @default(now())
  isResultPublished      Boolean             @default(false)
  expectedSubjects       Int                 @default(0)
  showPositionOnReport   Boolean             @default(true)
  showFeesOnReport       Boolean             @default(true)
  showAttendanceOnReport Boolean             @default(true)
  reportLayout           String?             @default("classic")
  attendanceRecords      AttendanceRecord[]
  CBTExam                CBTExam[]
  classTeacher           User?               @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  school                 School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  ClassFeeStructure      ClassFeeStructure[]
  subjects               ClassSubject[]
  curriculums            Curriculum[]
  examRepo               ExamRepository[]
  Homework               Homework[]
  LearningResource       LearningResource[]
  lessonNotes            LessonNote[]
  lessonPlans            LessonPlan[]
  toPromotions           PromotionHistory[]  @relation("ToClass")
  fromPromotions         PromotionHistory[]  @relation("FromClass")
  quranTargets           QuranTarget[]
  results                Result[]
  resultPublications     ResultPublication[]
  students               Student[]
  reportCards            StudentReportCard[]
  timetables             Timetable[]

  @@unique([schoolId, name, arm])
}

model ClassSubject {
  id             Int                 @id @default(autoincrement())
  schoolId       Int
  classId        Int
  subjectId      Int
  periodsPerWeek Int                 @default(1)
  createdAt      DateTime            @default(now())
  subject        Subject             @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class          Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  school         School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments    TeacherAssignment[]

  @@unique([schoolId, classId, subjectId])
}

model TeacherAssignment {
  id                Int              @id @default(autoincrement())
  schoolId          Int
  teacherId         Int
  classSubjectId    Int
  termId            Int?
  academicSessionId Int?
  createdAt         DateTime         @default(now())
  AcademicSession   AcademicSession? @relation(fields: [academicSessionId], references: [id])
  Term              Term?            @relation(fields: [termId], references: [id])
  classSubject      ClassSubject     @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)
  teacher           User             @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school            School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, teacherId, classSubjectId, termId])
}

model AcademicSession {
  id                Int                 @id @default(autoincrement())
  schoolId          Int
  name              String
  startDate         DateTime
  endDate           DateTime
  isCurrent         Boolean             @default(false)
  createdAt         DateTime            @default(now())
  school            School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  attendanceRecords AttendanceRecord[]
  CBTExam           CBTExam[]
  ClassFeeStructure ClassFeeStructure[]
  examCards         ExamCard[]
  FeeRecord         FeeRecord[]
  Homework          Homework[]
  interventions     Intervention[]
  LearningResource  LearningResource[]
  MiscellaneousFee  MiscellaneousFee[]
  promotionHistory  PromotionHistory[]
  quranTargets      QuranTarget[]
  results           Result[]
  reportCards       StudentReportCard[]
  TeacherAssignment TeacherAssignment[]
  terms             Term[]

  @@unique([schoolId, name])
}

model Term {
  id                 Int                 @id @default(autoincrement())
  schoolId           Int
  academicSessionId  Int
  name               String
  startDate          DateTime
  endDate            DateTime
  nextTermBeginsDate DateTime?
  isCurrent          Boolean             @default(false)
  createdAt          DateTime            @default(now())
  attendanceRecords  AttendanceRecord[]
  CBTExam            CBTExam[]
  ClassFeeStructure  ClassFeeStructure[]
  examCards          ExamCard[]
  FeeRecord          FeeRecord[]
  Homework           Homework[]
  interventions      Intervention[]
  LearningResource   LearningResource[]
  MiscellaneousFee   MiscellaneousFee[]
  quranTargets       QuranTarget[]
  results            Result[]
  resultPublications ResultPublication[]
  reportCards        StudentReportCard[]
  TeacherAssignment  TeacherAssignment[]
  academicSession    AcademicSession     @relation(fields: [academicSessionId], references: [id])
  school             School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, academicSessionId, name])
}

model Result {
  id                Int             @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  academicSessionId Int
  termId            Int
  classId           Int
  subjectId         Int
  assignment1Score  Float?
  assignment2Score  Float?
  test1Score        Float?
  test2Score        Float?
  examScore         Float?
  totalScore        Float
  grade             String?
  positionInClass   Int?
  classAverage      Float?
  teacherId         Int?
  isSubmitted       Boolean         @default(false)
  submittedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  student           Student         @relation(fields: [studentId], references: [id])
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id])
  term              Term            @relation(fields: [termId], references: [id])
  class             Class           @relation(fields: [classId], references: [id])
  subject           Subject         @relation(fields: [subjectId], references: [id])
  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, subjectId, termId, academicSessionId])
  @@index([schoolId, studentId, termId])
  @@index([schoolId, classId, subjectId])
}

model AttendanceRecord {
  id                Int             @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  classId           Int
  academicSessionId Int
  termId            Int
  date              DateTime
  status            String          @default("present")
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  student           Student         @relation(fields: [studentId], references: [id])
  class             Class           @relation(fields: [classId], references: [id])
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id])
  term              Term            @relation(fields: [termId], references: [id])
  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, date])
  @@index([schoolId, classId, date])
}

model StaffAttendance {
  id           Int       @id @default(autoincrement())
  schoolId     Int
  userId       Int
  date         DateTime
  checkInTime  DateTime?
  checkOutTime DateTime?
  status       String
  lateMinutes  Int?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  verifiedById Int?
  verifiedAt   DateTime?
  verifier     User?     @relation("AttendanceVerifier", fields: [verifiedById], references: [id])
  user         User      @relation("StaffUser", fields: [userId], references: [id], onDelete: Cascade)
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, userId, date])
  @@index([userId, date])
  @@index([schoolId, date])
}

model Notice {
  id            Int       @id @default(autoincrement())
  schoolId      Int
  title         String
  content       String
  audience      String    @default("all")
  category      String    @default("general") // general, urgent, event, holiday, exam
  isPinned      Boolean   @default(false)
  attachmentUrl String?
  isActive      Boolean   @default(true)
  authorId      Int
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  author        User      @relation("NoticeAuthor", fields: [authorId], references: [id])
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model ExamCard {
  id                Int             @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  academicSessionId Int
  termId            Int
  cardNumber        String
  issuedAt          DateTime        @default(now())
  student           Student         @relation(fields: [studentId], references: [id])
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id])
  term              Term            @relation(fields: [termId], references: [id])
  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, cardNumber])
  @@unique([schoolId, studentId, termId, academicSessionId])
}

model Timetable {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  classId     Int
  subjectId   Int?
  dayOfWeek   String
  startTime   String
  endTime     String
  type        String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  subject     Subject? @relation(fields: [subjectId], references: [id])
  class       Class    @relation(fields: [classId], references: [id])
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, classId])
}

model ExamRepository {
  id                Int      @id @default(autoincrement())
  schoolId          Int
  teacherId         Int
  subjectId         Int
  classId           Int
  title             String
  driveLink         String?
  fileUrl           String?
  termId            Int
  academicSessionId Int
  status            String   @default("submitted")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  class             Class    @relation(fields: [classId], references: [id])
  subject           Subject  @relation(fields: [subjectId], references: [id])
  teacher           User     @relation(fields: [teacherId], references: [id])
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model LessonPlan {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  teacherId Int
  subjectId Int
  classId   Int
  week      Int
  topic     String
  content   String
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     Class    @relation(fields: [classId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   User     @relation(fields: [teacherId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model LessonNote {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  teacherId Int
  subjectId Int
  classId   Int
  week      Int
  topic     String
  content   String
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     Class    @relation(fields: [classId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacher   User     @relation(fields: [teacherId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Curriculum {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  subjectId Int
  classId   Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  class     Class    @relation(fields: [classId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, subjectId, classId])
}

model Counter {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  entity    String
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, entity])
}

model Department {
  id        Int       @id @default(autoincrement())
  schoolId  Int
  name      String
  headId    Int?      @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  head      User?     @relation("DepartmentHead", fields: [headId], references: [id])
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  nudges    Nudge[]
  subjects  Subject[]
  staff     User[]    @relation("DepartmentStaff")

  @@unique([schoolId, name])
}

model Nudge {
  id           Int        @id @default(autoincrement())
  senderId     Int
  receiverId   Int
  departmentId Int
  type         String
  message      String?
