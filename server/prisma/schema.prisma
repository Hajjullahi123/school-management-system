generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GlobalSettings {
  id           Int     @id @default(1)
  facebookUrl  String?
  instagramUrl String?
  whatsappUrl  String?
  websiteUrl   String?
  contactPhone String?
  contactEmail String?

  // Platform Platform Compensation Keys (For SaaS Income)
  platformPaystackKey    String?
  platformFlutterwaveKey String?
  platformSecretKey      String? // For internal verification

  // Automated Backups (SuperAdmin Level)
  s3AccessKey         String?
  s3SecretKey         String?
  s3BucketName        String?
  s3Region            String? @default("us-east-1")
  enableAutoBackup    Boolean @default(false)
  backupRetentionDays Int     @default(30)

  basicPrice    Float @default(50000)
  standardPrice Float @default(120000)
  premiumPrice  Float @default(250000)

  latestAppVersion String? @default("1.0.0")
  apkDownloadUrl   String?

  // AI Configuration (Platform Level Fallback)
  geminiApiKey String?
  groqApiKey   String?

  // WhatsApp Platform Fallback
  whatsappProvider      String? @default("twilio")
  whatsappPhoneNumber   String?
  twilioAccountSid      String?
  twilioAuthToken       String?
  metaAccessToken       String?
  metaPhoneNumberId     String?
  metaBusinessAccountId String?
  metaVerifyToken       String?

  updatedAt DateTime @updatedAt
}

model School {
  id                    Int     @id @default(autoincrement())
  slug                  String  @unique // e.g. "darul-quran"
  code                  String? @unique // e.g. "AMA" for Amana
  customDomain          String? @unique // e.g. "portal.darulquran.com"
  name                  String
  address               String?
  phone                 String?
  email                 String?
  motto                 String?
  logoUrl               String?
  principalSignatureUrl String?
  openingHours          String? @default("Mon - Fri: 8:00 AM - 4:00 PM")
  welcomeTitle          String? @default("Building a Brighter Future Together")
  welcomeMessage        String? @default("Providing a supportive and innovative environment where every student can achieve their full potential and prepare for success in an ever-changing world.")
  primaryColor          String  @default("#1e40af")
  secondaryColor        String  @default("#3b82f6")
  accentColor           String  @default("#60a5fa")

  // Settings & Integrations (School's own keys for fee collection)
  paystackPublicKey    String?
  paystackSecretKey    String?
  flutterwavePublicKey String?
  flutterwaveSecretKey String?
  enableOnlinePayment  Boolean @default(false)

  // Communication
  emailUser     String?
  emailPassword String?
  emailHost     String?
  emailPort     Int?    @default(465)
  emailSecure   Boolean @default(true)
  smsUsername   String?
  smsApiKey     String?
  smsSenderId   String?
  enableSMS     Boolean @default(false)

  // WhatsApp Bot Configuration
  whatsappBotEnabled    Boolean @default(false)
  whatsappProvider      String? @default("twilio")
  whatsappPhoneNumber   String?
  twilioAccountSid      String?
  twilioAuthToken       String?
  metaAccessToken       String?
  metaPhoneNumberId     String?
  metaBusinessAccountId String?
  metaVerifyToken       String?

  // Subscription Management
  package           String    @default("basic") // basic, standard, premium
  subscriptionEnds  DateTime?
  isSubscriptionActive Boolean   @default(true)
  paymentReference  String?

  // Relations
  users             User[]
  students          Student[]
  subjects          Subject[]
  academicSessions  AcademicSession[]
  terms             Term[]
  classes           Class[]
  assignments       TeacherAssignment[]
  feeStructures     FeeStructure[]
  payments          Payment[]
  examCards         ExamCard[]
  attendance        Attendance[]
  staffAttendance   StaffAttendance[]
  messages          Message[]
  timetables        Timetable[]
  notices           Notice[]
  examRepository    ExamRepository[]
  lessonPlans       LessonPlan[]
  lessonNotes       LessonNote[]
  curriculums       Curriculum[]
  resources         DepartmentResource[]
  counters          Counter[]
  departments       Department[]
  galleryItems      GalleryItem[]
  newsEvents        NewsEvent[]
  alumni            Alumni[]
  interventions     Intervention[]
  auditLogs         AuditLog[]
  holidays          Holiday[]
  miscFees          MiscFee[]
  adverts           Advert[]
  payrollVouchers   PayrollVoucher[]
  leaveRequests     LeaveRequest[]
  materialRequests  MaterialRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model User {
  id               Int      @id @default(autoincrement())
  schoolId         Int?
  username         String   @unique
  passwordHash     String   @default("password123")
  role             String   // superadmin, admin, teacher, accountant, principal, examination_officer, parent, student, alumni
  firstName        String
  lastName         String
  phone            String?
  email            String?
  photoUrl         String?
  isActive         Boolean  @default(true)
  
  // Specific for parents
  parentChildren   Student[] @relation("StudentParent")

  // Specific for alumni
  alumniProfile    Alumni?

  // Relations
  school           School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments      TeacherAssignment[]
  createdExams     ExamRepository[]
  lessonPlans      LessonPlan[]
  lessonNotes      LessonNote[]
  parentMessages   Message[] @relation("Sender")
  receivedMessages Message[] @relation("Receiver")
  notices          Notice[]  @relation("NoticeAuthor")
  headOfDepartment Department? @relation("DepartmentHead")
  departmentId     Int?
  department       Department? @relation("DepartmentStaff", fields: [departmentId], references: [id])
  sentNudges       Nudge[] @relation("NudgeSender")
  receivedNudges   Nudge[] @relation("NudgeReceiver")
  staffAttendance  StaffAttendance[]
  uploadedResources DepartmentResource[]
  auditedActions   AuditLog[]
  classSubjects    ClassSubject[]
  payrollRecords   PayrollRecord[]
  loanRequests     LoanRequest[]
  leaveRequests    LeaveRequest[]
  materialRequests MaterialRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([schoolId, username])
}

model Student {
  id               Int      @id @default(autoincrement())
  schoolId         Int
  studentId        String?  @unique // e.g. "STU/2026/001"
  firstName        String   @default("")
  lastName         String   @default("")
  middleName       String?
  gender           String
  dateOfBirth      DateTime?
  address          String?
  photoUrl         String?
  classId          Int?
  parentId         Int?
  isActive         Boolean  @default(true)

  // Relations
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class            Class?   @relation(fields: [classId], references: [id])
  parent           User?    @relation("StudentParent", fields: [parentId], references: [id])
  results          Result[]
  attendance       Attendance[]
  payments         Payment[]
  examCards        ExamCard[]
  quranTargets     QuranTarget[]
  quranRecords     QuranRecord[]
  interventions    Intervention[]
  academicRemarks  AcademicRemark[]
  cumulativeResults CumulativeResult[]
  miscFeePayments   MiscFeePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Subject {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  name        String
  code        String?
  isCore      Boolean  @default(false)
  departmentId Int?
  
  // Relations
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department  Department? @relation(fields: [departmentId], references: [id])
  classes     ClassSubject[]
  results     Result[]
  examRepo    ExamRepository[]
  lessonPlans LessonPlan[]
  lessonNotes LessonNote[]
  curriculums Curriculum[]
  quranTargets QuranTarget[]
  quranRecords QuranRecord[]
  interventions Intervention[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([schoolId, name])
}

model Class {
  id               Int      @id @default(autoincrement())
  schoolId         Int
  name             String   // e.g. "JSS 1"
  arm              String?  // e.g. "A"
  level            String?  // primary, secondary
  
  // Relations
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students         Student[]
  subjects         ClassSubject[]
  results          Result[]
  timetables       Timetable[]
  examRepo         ExamRepository[]
  lessonPlans      LessonPlan[]
  lessonNotes      LessonNote[]
  curriculums      Curriculum[]
  cumulativeResults CumulativeResult[]
  attendance       Attendance[]
  interventions    Intervention[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([schoolId, name, arm])
}

model ClassSubject {
  id          Int      @id @default(autoincrement())
  classId     Int
  subjectId   Int
  teacherId   Int?
  
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     User?    @relation(fields: [teacherId], references: [id])
  assignments TeacherAssignment[]

  @@unique([classId, subjectId])
}

model TeacherAssignment {
  id             Int          @id @default(autoincrement())
  schoolId       Int
  teacherId      Int
  classSubjectId Int
  
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher        User         @relation(fields: [teacherId], references: [id])
  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)

  // @@unique([teacherId, classSubjectId])
}

model AcademicSession {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  name        String   // e.g. "2025/2026"
  isCurrent   Boolean  @default(false)
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms       Term[]
  results     Result[]
  payments    Payment[]
  examRepo    ExamRepository[]
  cumulativeResults CumulativeResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([schoolId, name])
}

model Term {
  id                Int      @id @default(autoincrement())
  schoolId          Int
  academicSessionId Int
  name              String   // e.g. "First Term"
  isCurrent         Boolean  @default(false)
  startDate         DateTime?
  endDate           DateTime?
  
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id])
  results           Result[]
  academicRemarks   AcademicRemark[]
  payments          Payment[]
  examRepo          ExamRepository[]
  cumulativeResults CumulativeResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([schoolId, academicSessionId, name])
}

model Result {
  id                Int      @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  subjectId         Int
  classId           Int
  termId            Int
  academicSessionId Int
  
  // Continuous Assessment Scores
  assignment1Score  Float?   @default(0)
  assignment2Score  Float?   @default(0)
  test1Score        Float?   @default(0)
  test2Score        Float?   @default(0)
  examScore         Float?   @default(0)
  totalScore        Float?   @default(0)
  grade             String?
  remark            String?
  
  isSubmitted       Boolean  @default(false)
  submittedAt       DateTime?
  
  student           Student  @relation(fields: [studentId], references: [id])
  subject           Subject  @relation(fields: [subjectId], references: [id])
  class             Class    @relation(fields: [classId], references: [id])
  term              Term     @relation(fields: [termId], references: [id])
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subjectId, termId, academicSessionId])
}

model CumulativeResult {
  id                Int      @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  classId           Int
  academicSessionId Int
  termId            Int?     // Optional: specific term reference if needed
  
  average           Float?
  totalScore        Float?
  position          Int?
  decision          String?  // PROMOTED, PROMOTED_ON_TRIAL, REPEATED
  
  student           Student  @relation(fields: [studentId], references: [id])
  class             Class    @relation(fields: [classId], references: [id])
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id])
  term              Term?    @relation(fields: [termId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, classId, academicSessionId])
}

model AcademicRemark {
  id        Int      @id @default(autoincrement())
  studentId Int
  termId    Int
  principalRemark String?
  teacherRemark   String?
  attendance      Int?
  totalAttendance Int?
  
  student   Student  @relation(fields: [studentId], references: [id])
  term      Term     @relation(fields: [termId], references: [id])

  @@unique([studentId, termId])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  studentId Int
  classId   Int
  date      DateTime
  status    String   // PRESENT, ABSENT, LATE
  remark    String?
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id])
  class     Class    @relation(fields: [classId], references: [id])

  @@unique([studentId, date])
}

model StaffAttendance {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  staffId   Int?
  date      DateTime
  status    String   // PRESENT, ABSENT, LATE
  clockIn   DateTime?
  clockOut  DateTime?
  remark    String?
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff     User?    @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
}

model Message {
  id         Int      @id @default(autoincrement())
  schoolId   Int
  senderId   Int
  receiverId Int
  content    String
  isRead     Boolean  @default(false)
  
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender     User     @relation("Sender", fields: [senderId], references: [id])
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id])

  createdAt  DateTime @default(now())
}

model Notice {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  authorId  Int
  title     String
  content   String
  audience  String   // all, teachers, parents, class:ID, user:ID
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  author    User     @relation("NoticeAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

model FeeStructure {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  name      String   // e.g. "SS 1 First Term Fees"
  amount    Float
  classLevel String? // e.g. "SS 1"
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payments  Payment[]

  createdAt DateTime @default(now())
}

model Payment {
  id                Int      @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  feeStructureId    Int
  academicSessionId Int
  termId            Int
  amount            Float
  method            String   // CASH, ONLINE, TRANSFER
  status            String   // PENDING, PAID, PARTIAL
  reference         String?  @unique
  
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student  @relation(fields: [studentId], references: [id])
  feeStructure      FeeStructure @relation(fields: [feeStructureId], references: [id])
  term              Term     @relation(fields: [termId], references: [id])
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id])

  createdAt DateTime @default(now())
}

model MiscFee {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  name        String
  description String?
  amount      Float
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payments    MiscFeePayment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MiscFeePayment {
  id        Int      @id @default(autoincrement())
  miscFeeId Int
  studentId Int
  amount    Float
  method    String
  reference String?  @unique
  date      DateTime @default(now())
  
  miscFee   MiscFee  @relation(fields: [miscFeeId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id])
}

model ExamCard {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  studentId Int
  examNumber String  @unique
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id])

  createdAt DateTime @default(now())
}

model Timetable {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  classId   Int
  day       String   // Monday, Tuesday, etc.
  startTime String
  endTime   String
  subject   String
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
}

model ExamRepository {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  teacherId Int
  subjectId Int
  classId   Int
  termId    Int
  academicSessionId Int
  
  title     String
  fileUrl   String?
  driveLink String?
  status    String   @default("submitted") // submitted, approved, rejected
  feedback  String?
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher   User     @relation(fields: [teacherId], references: [id])
  subject   Subject  @relation(fields: [subjectId], references: [id])
  class     Class    @relation(fields: [classId], references: [id])
  term      Term     @relation(fields: [termId], references: [id])
  session   AcademicSession @relation(fields: [academicSessionId], references: [id])

  createdAt DateTime @default(now())
}

model LessonPlan {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  teacherId Int
  subjectId Int
  classId   Int
  week      Int
  topic     String
  content   String? // The plan details (HTML/JSON) - Now optional if using link
  fileLink  String? // New: Link to external drive/file
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMMENTED
  hodFeedback String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher User    @relation(fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
}

model LessonNote {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  teacherId Int
  subjectId Int
  classId   Int
  week      Int
  topic     String
  content   String? // The note details (HTML/JSON) - Now optional if using link
  fileLink  String? // New: Link to external drive/file
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED, COMMENTED
  hodFeedback String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher User    @relation(fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])
}

model Curriculum {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  subjectId Int
  classId   Int
  content   String // The syllabus/curriculum details for AI
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([schoolId, subjectId, classId])
}

model DepartmentResource {
  id           Int        @id @default(autoincrement())
  schoolId     Int
  departmentId Int
  uploaderId   Int
  title        String
  description  String?
  fileUrl      String
  fileType     String     // "PDF", "DOCX", "LINK", etc.
  category     String     @default("OTHER") // "CURRICULUM", "LESSON_PLAN", "PAST_PAPER", "OTHER"
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  school      School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department  Department @relation(fields: [departmentId], references: [id])
  uploader    User       @relation(fields: [uploaderId], references: [id])
}

model Counter {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  entity    String // "STUDENT", "STAFF", "ALUMNI", "INVOICE"
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, entity])
}

model ShowcaseSchool {
  id        Int      @id @default(autoincrement())
  name      String
  logoUrl   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Advert {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String
  targetUrl String?
  isActive  Boolean  @default(true)
  schoolId  Int?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  name      String
  headId    Int?     @unique // Every department can have ONE head
  lessonPlanLink String? // New: Link to shared drive for the department
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  head   User?  @relation("DepartmentHead", fields: [headId], references: [id])
  staff  User[] @relation("DepartmentStaff")
  subjects Subject[]
  nudges Nudge[]
  resources DepartmentResource[]

  @@unique([schoolId, name])
}

model Nudge {
  id           Int        @id @default(autoincrement())
  senderId     Int
  sender       User       @relation("NudgeSender", fields: [senderId], references: [id])
  receiverId   Int
  receiver     User       @relation("NudgeReceiver", fields: [receiverId], references: [id])
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  type         String     // "TARGET_MISSING", "PROGRESS_LAGGING", "GENERAL"
  message      String?
  isRead       Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
}

model QuranTarget {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  studentId   Int?
  subjectId   Int?
  targetSurah String?
  targetJuz   Int?
  targetPage  Int?
  deadline    DateTime?
  
  student     Student? @relation(fields: [studentId], references: [id])
  subject     Subject? @relation(fields: [subjectId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
}

model QuranRecord {
  id           Int      @id @default(autoincrement())
  schoolId     Int
  studentId    Int
  teacherId    Int
  subjectId    Int?
  type         String   // HIFZ, MURAAJAH, TILAWAH, QAIDAH
  surah        String?
  juz          Int?
  page         Int?
  verseStart   Int?
  verseEnd     Int?
  quality      String?  // EXCELLENT, GOOD, FAIR, POOR
  remarks      String?
  
  student      Student  @relation(fields: [studentId], references: [id])
  subject      Subject? @relation(fields: [subjectId], references: [id])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
}

model GalleryItem {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  title       String
  description String?
  imageUrl    String
  category    String   @default("GENERAL")
  createdAt   DateTime @default(now())
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model NewsEvent {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  title       String
  content     String
  type        String   // NEWS, EVENT
  eventDate   DateTime?
  imageUrl    String?
  createdAt   DateTime @default(now())
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Alumni {
  id             Int      @id @default(autoincrement())
  schoolId       Int
  userId         Int?     @unique
  graduationYear Int
  currentProfession String?
  location       String?
  isVerified     Boolean  @default(false)
  
  school         School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user           User?    @relation(fields: [userId], references: [id])

  createdAt      DateTime @default(now())
}

model Intervention {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  studentId   Int
  teacherId   Int?
  subjectId   Int?
  classId     Int?
  issue       String
  actionPlan  String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id])
  subject     Subject? @relation(fields: [subjectId], references: [id])
  class       Class?   @relation(fields: [classId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  userId      Int
  action      String   // CREATE, UPDATE, DELETE, LOGIN
  resource    String   // STUDENT, RESULT, etc.
  details     String?  // JSON string
  ipAddress   String?
  createdAt   DateTime @default(now())

  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])
}

model Holiday {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  name        String
  startDate   DateTime
  endDate     DateTime
  description String?
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

// ================= HR & PAYROLL MODULE =================

model PayrollVoucher {
  id           Int           @id @default(autoincrement())
  schoolId     Int
  month        Int           // 1-12
  year         Int
  status       String        @default("DRAFT") // DRAFT, FINALIZED, PAID
  totalGross   Float         @default(0)
  totalNet     Float         @default(0)
  totalDeductions Float      @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  records      PayrollRecord[]

  @@unique([schoolId, month, year])
}

model PayrollRecord {
  id              Int               @id @default(autoincrement())
  staffId         Int
  voucherId       Int
  baseSalary      Float
  totalAllowances Float             @default(0)
  totalDeductions Float             @default(0)
  netPay          Float
  status          String            @default("PENDING") // PENDING, PAID
  
  staff           User              @relation(fields: [staffId], references: [id])
  voucher         PayrollVoucher    @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  allowances      PayrollAllowance[]
  deductions      PayrollDeduction[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([staffId, voucherId])
}

model PayrollAllowance {
  id              Int           @id @default(autoincrement())
  payrollRecordId Int
  type            String        // BONUS, TRANSPORT, HOUSING, etc.
  amount          Float
  description     String?
  
  payrollRecord   PayrollRecord @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade)
}

model PayrollDeduction {
  id              Int           @id @default(autoincrement())
  payrollRecordId Int
  amount          Float
  reason          String        // TAX, LOAN_REPAYMENT, LATE_COMING, etc.
  
  payrollRecord   PayrollRecord @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade)
}

model LoanRequest {
  id             Int       @id @default(autoincrement())
  staffId        Int
  amount         Float
  reason         String
  repaymentMonths Int      @default(1)
  repaidMonths   Int      @default(0)
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED, COMPLETED
  processedById  Int?
  processedAt    DateTime?
  
  staff          User      @relation(fields: [staffId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model LeaveRequest {
  id             Int       @id @default(autoincrement())
  schoolId       Int
  staffId        Int
  type           String    // SICK, ANNUAL, EXCUSE, MATERNITY
  startDate      DateTime
  endDate        DateTime
  reason         String
  status         String    @default("PENDING") // PENDING, APPROVED, REJECTED
  processedById  Int?
  processedAt    DateTime?
  
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff          User      @relation(fields: [staffId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model MaterialRequest {
  id             Int       @id @default(autoincrement())
  schoolId       Int
  staffId        Int
  items          String    // JSON string of items requested
  priority       String    @default("NORMAL") // NORMAL, URGENT
  status         String    @default("PENDING") // PENDING, APPROVED, DISBURSED, REJECTED
  processedById  Int?
  processedAt    DateTime?
  
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  staff          User      @relation(fields: [staffId], references: [id])
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
