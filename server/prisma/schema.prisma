generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model GlobalSettings {
  id           Int     @id @default(1)
  facebookUrl  String?
  instagramUrl String?
  whatsappUrl  String?
  websiteUrl   String?
  contactPhone String?
  contactEmail String?

  // Platform Platform Compensation Keys (For SaaS Income)
  platformPaystackKey    String?
  platformFlutterwaveKey String?
  platformSecretKey      String? // For internal verification

  // Automated Backups (SuperAdmin Level)
  s3AccessKey         String?
  s3SecretKey         String?
  s3BucketName        String?
  s3Region            String? @default("us-east-1")
  enableAutoBackup    Boolean @default(false)
  backupRetentionDays Int     @default(30)

  basicPrice    Float @default(50000)
  standardPrice Float @default(120000)
  premiumPrice  Float @default(250000)

  latestAppVersion String? @default("1.0.0")
  apkDownloadUrl   String?

  // AI Configuration (Platform Level Fallback)
  geminiApiKey String?
  groqApiKey   String?

  // WhatsApp Platform Fallback
  whatsappProvider      String? @default("twilio")
  whatsappPhoneNumber   String?
  twilioAccountSid      String?
  twilioAuthToken       String?
  metaAccessToken       String?
  metaPhoneNumberId     String?
  metaBusinessAccountId String?
  metaVerifyToken       String?

  updatedAt DateTime @updatedAt
}

model School {
  id                    Int     @id @default(autoincrement())
  slug                  String  @unique // e.g. "darul-quran"
  code                  String? @unique // e.g. "AMA" for Amana
  customDomain          String? @unique // e.g. "portal.darulquran.com"
  name                  String
  address               String?
  phone                 String?
  email                 String?
  motto                 String?
  logoUrl               String?
  principalSignatureUrl String?
  openingHours          String? @default("Mon - Fri: 8:00 AM - 4:00 PM")
  welcomeTitle          String? @default("Building a Brighter Future Together")
  welcomeMessage        String? @default("Providing a supportive and innovative environment where every student can achieve their full potential and prepare for success in an ever-changing world.")
  primaryColor          String  @default("#1e40af")
  secondaryColor        String  @default("#3b82f6")
  accentColor           String  @default("#60a5fa")

  // Settings & Integrations (School's own keys for fee collection)
  paystackPublicKey    String?
  paystackSecretKey    String?
  flutterwavePublicKey String?
  flutterwaveSecretKey String?
  enableOnlinePayment  Boolean @default(false)

  // Communication
  emailUser     String?
  emailPassword String?
  emailHost     String?
  emailPort     Int?    @default(465)
  emailSecure   Boolean @default(true)
  smsUsername   String?
  smsApiKey     String?
  smsSenderId   String?
  enableSMS     Boolean @default(false)

  // WhatsApp Bot Configuration
  whatsappBotEnabled    Boolean @default(false)
  whatsappProvider      String? @default("twilio")
  whatsappPhoneNumber   String?
  twilioAccountSid      String?
  twilioAuthToken       String?
  metaAccessToken       String?
  metaPhoneNumberId     String?
  metaBusinessAccountId String?
  metaVerifyToken       String?

  // Subscription Management
  packageType       String    @default("basic") // basic, standard, premium
  isActivated       Boolean   @default(true)
  subscriptionEnds  DateTime?
  isSubscriptionActive Boolean   @default(true)
  paymentReference  String?

  // Weekend Configuration
  weekendDays       String?   @default("0,6") // Comma separated day indices (0=Sun, 6=Sat)

  // Relations
  users             User[]
  students          Student[]
  subjects          Subject[]
  academicSessions  AcademicSession[]
  terms             Term[]
  classes           Class[]
  assignments       TeacherAssignment[]
  feeStructures     FeeStructure[]
  payments          Payment[]
  examCards         ExamCard[]
  attendance        Attendance[]
  attendanceRecords AttendanceRecord[]
  staffAttendance   StaffAttendance[]
  messages          Message[]
  timetables        Timetable[]
  notices           Notice[]
  examRepository    ExamRepository[]
  lessonPlans       LessonPlan[]
  lessonNotes       LessonNote[]
  curriculums       Curriculum[]
  resources         DepartmentResource[]
  counters          Counter[]
  departments       Department[]
  galleryItems      GalleryItem[]
  newsEvents        NewsEvent[]
  alumni            Alumni[]
  interventions     Intervention[]
  auditLogs         AuditLog[]
  holidays          Holiday[]
  schoolHolidays    SchoolHoliday[]
  miscFees          MiscFee[]
  adverts           Advert[]
  payrollVouchers   PayrollVoucher[]
  leaveRequests     LeaveRequest[]
  materialRequests  MaterialRequest[]
  teachers           Teacher[]
  resultPublications ResultPublication[]
  quranRecords       QuranRecord[]
  quranTargets       QuranTarget[]
  studentReportCards StudentReportCard[]
  promotionHistory   PromotionHistory[]
  certificates       Certificate[]
  testimonials       Testimonial[]
  results            Result[]
  classSubjects      ClassSubject[]
  teacherAvailabilities TeacherAvailability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model User {
  id                 Int                 @id @default(autoincrement())
  schoolId           Int?
  username           String
  passwordHash       String              @default("password123")
  role               String              // superadmin, admin, teacher, accountant, principal, examination_officer, parent, student, alumni
  firstName          String
  lastName           String
  phone              String?
  email              String?
  photoUrl           String?
  signatureUrl       String?
  isActive           Boolean             @default(true)
  mustChangePassword Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @default(now()) @updatedAt

  // Relations
  school             School?             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher            Teacher?
  student            Student?
  parentChildren     Student[]           @relation("StudentParent")
  
  departmentAsHead   Department?         @relation("DepartmentHead")
  departmentId       Int?
  department         Department?         @relation("DepartmentStaff", fields: [departmentId], references: [id])

  assignments        TeacherAssignment[]
  createdExams       ExamRepository[]
  lessonPlans        LessonPlan[]
  lessonNotes        LessonNote[]
  parentMessages     Message[]           @relation("Sender")
  receivedMessages   Message[]           @relation("Receiver")
  notices            Notice[]            @relation("NoticeAuthor")
  classesAsTeacher   Class[]             @relation("ClassTeacher")
  sentNudges         Nudge[]             @relation("NudgeSender")
  receivedNudges     Nudge[]             @relation("NudgeReceiver")
  staffAttendance    StaffAttendance[]   @relation("StaffUser")
  verifiedAttendance StaffAttendance[]   @relation("AttendanceVerifier")
  uploadedResources  DepartmentResource[]
  auditedActions     AuditLog[]
  classSubjects      ClassSubject[]
  payrollRecords     PayrollRecord[]
  loanRequests       LoanRequest[]
  leaveRequests      LeaveRequest[]
  materialRequests   MaterialRequest[]
  interventions      Intervention[]
  quranRecords       QuranRecord[]       @relation("QuranTeacher")
  certificatesIssued Certificate[]       @relation("CertificateIssuer")
  testimonialsIssued Testimonial[]       @relation("TestimonialIssuer")

  @@unique([schoolId, username])
  @@unique([schoolId, email])
}

model Student {
  id                  Int                 @id @default(autoincrement())
  schoolId            Int
  userId              Int?                @unique
  parentId            Int?
  admissionNumber     String              @default("")
  classId             Int?
  dateOfBirth         DateTime?
  gender              String?
  stateOfOrigin       String?
  nationality         String?             @default("Nigerian")
  address             String?
  photoUrl            String?
  parentGuardianName  String?
  parentGuardianPhone String?
  parentEmail         String?
  bloodGroup          String?
  genotype            String?
  disability          String?
  name                String?
  rollNo              String?
  class               String?
  parentPhone         String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @default(now()) @updatedAt
  middleName          String?
  status              String              @default("active") // active, graduated, withdrawn, alumni
  clubs               String?
  isScholarship       Boolean             @default(false)
  isExamRestricted    Boolean             @default(false)
  examRestrictionReason String?

  // Relations
  school            School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user              User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  classModel        Class?              @relation(fields: [classId], references: [id])
  parent            User?               @relation("StudentParent", fields: [parentId], references: [id])
  
  results           Result[]
  attendance        Attendance[]
  attendanceRecords AttendanceRecord[]
  payments          Payment[]
  examCards         ExamCard[]
  quranTargets      QuranTarget[]
  quranRecords      QuranRecord[]
  interventions     Intervention[]
  academicRemarks   AcademicRemark[]
  cumulativeResults CumulativeResult[]
  miscFeePayments   MiscFeePayment[]
  alumniProfile     Alumni?
  reportCards       StudentReportCard[]
  promotionHistory  PromotionHistory[]
  homeworkSubmissions HomeworkSubmission[]
  certificate       Certificate?
  testimonial       Testimonial?

  @@unique([schoolId, admissionNumber])
  @@unique([schoolId, rollNo])
}

model Teacher {
  id               Int      @id @default(autoincrement())
  schoolId         Int
  userId           Int      @unique
  staffId          String?  @unique
  specialization   String?
  photoUrl         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availabilities   TeacherAvailability[]

  @@unique([schoolId, staffId])
}

model TeacherAvailability {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  teacherId   Int
  dayOfWeek   String
  startTime   String?
  endTime     String?
  isAvailable Boolean  @default(false)

  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model Subject {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  name        String
  code        String?
  isCore      Boolean  @default(false)
  departmentId Int?
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department  Department? @relation(fields: [departmentId], references: [id])
  classes     ClassSubject[]
  results     Result[]
  examRepo    ExamRepository[]
  lessonPlans LessonPlan[]
  lessonNotes LessonNote[]
  curriculums Curriculum[]
  quranTargets QuranTarget[]
  quranRecords QuranRecord[]
  interventions Intervention[]
  timetables   Timetable[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([schoolId, name])
}

model Class {
  id               Int      @id @default(autoincrement())
  schoolId         Int
  name             String
  arm              String?
  level            String?
  classTeacherId   Int?     @unique
  
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classTeacher     User?    @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  students         Student[]
  subjects         ClassSubject[]
  results          Result[]
  timetables       Timetable[]
  examRepo         ExamRepository[]
  lessonPlans      LessonPlan[]
  lessonNotes      LessonNote[]
  curriculums      Curriculum[]
  cumulativeResults CumulativeResult[]
  attendance       Attendance[]
  attendanceRecords AttendanceRecord[]
  interventions    Intervention[]
  reportCards      StudentReportCard[]
  resultPublications ResultPublication[]
  fromPromotions   PromotionHistory[] @relation("FromClass")
  toPromotions     PromotionHistory[] @relation("ToClass")
  quranTargets     QuranTarget[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([schoolId, name, arm])
}

model ClassSubject {
  id          Int      @id @default(autoincrement())
  schoolId    Int      @default(1)
  classId     Int
  subjectId   Int
  teacherId   Int?
  periodsPerWeek Int   @default(1)
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher     User?    @relation(fields: [teacherId], references: [id])
  assignments TeacherAssignment[]

  @@unique([classId, subjectId])
}

model TeacherAssignment {
  id             Int          @id @default(autoincrement())
  schoolId       Int
  teacherId      Int
  classSubjectId Int
  
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher        User         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  classSubject   ClassSubject @relation(fields: [classSubjectId], references: [id], onDelete: Cascade)

  @@unique([schoolId, teacherId, classSubjectId])
}

model AcademicSession {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  name        String
  startDate   DateTime @default(now())
  endDate     DateTime @default(now())
  isCurrent   Boolean  @default(false)
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  terms       Term[]
  results     Result[]
  payments    Payment[]
  examRepo    ExamRepository[]
  cumulativeResults CumulativeResult[]
  promotionHistory  PromotionHistory[]
  interventions     Intervention[]
  attendanceRecords AttendanceRecord[]
  quranTargets      QuranTarget[]
  reportCards       StudentReportCard[]
  examCards         ExamCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([schoolId, name])
}

model Term {
  id                Int      @id @default(autoincrement())
  schoolId          Int
  academicSessionId Int
  name              String
  isCurrent         Boolean  @default(false)
  startDate         DateTime @default(now())
  endDate           DateTime @default(now())
  nextTermBeginsDate DateTime?
  
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)
  results           Result[]
  academicRemarks   AcademicRemark[]
  payments          Payment[]
  examRepo          ExamRepository[]
  cumulativeResults CumulativeResult[]
  interventions     Intervention[]
  resultPublications ResultPublication[]
  attendanceRecords AttendanceRecord[]
  quranTargets      QuranTarget[]
  reportCards       StudentReportCard[]
  examCards         ExamCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([schoolId, academicSessionId, name])
}

model Result {
  id                Int      @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  subjectId         Int
  classId           Int
  termId            Int
  academicSessionId Int
  
  assignment1Score  Float?   @default(0)
  assignment2Score  Float?   @default(0)
  test1Score        Float?   @default(0)
  test2Score        Float?   @default(0)
  examScore         Float?   @default(0)
  totalScore        Float?   @default(0)
  grade             String?
  remark            String?
  
  isSubmitted       Boolean  @default(false)
  submittedAt       DateTime?
  
  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject           Subject         @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class             Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  term              Term            @relation(fields: [termId], references: [id], onDelete: Cascade)
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, studentId, subjectId, termId, academicSessionId])
}

model CumulativeResult {
  id                Int      @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  classId           Int
  academicSessionId Int
  termId            Int?
  
  average           Float?
  totalScore        Float?
  position          Int?
  decision          String?  // PROMOTED, PROMOTED_ON_TRIAL, REPEATED
  
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class             Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)
  term              Term?    @relation(fields: [termId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, classId, academicSessionId])
}

model AcademicRemark {
  id        Int      @id @default(autoincrement())
  studentId Int
  termId    Int
  principalRemark String?
  teacherRemark   String?
  attendance      Int?
  totalAttendance Int?
  
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([studentId, termId])
}

model Attendance {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  studentId Int
  classId   Int
  date      DateTime
  status    String   // PRESENT, ABSENT, LATE
  remark    String?
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
}

model AttendanceRecord {
  id                Int             @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  classId           Int
  academicSessionId Int
  termId            Int
  date              DateTime
  status            String          @default("present")
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  term              Term            @relation(fields: [termId], references: [id], onDelete: Cascade)
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)
  class             Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentId, date])
}

model StaffAttendance {
  id            Int      @id @default(autoincrement())
  schoolId      Int
  userId        Int      @default(1)
  date          DateTime
  checkInTime   DateTime?
  checkOutTime  DateTime?
  status        String   // present, late, absent, half-day
  lateMinutes   Int?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user          User     @relation("StaffUser", fields: [userId], references: [id], onDelete: Cascade)
  verifiedById  Int?
  verifiedAt    DateTime?
  verifier      User?    @relation("AttendanceVerifier", fields: [verifiedById], references: [id])

  @@unique([schoolId, userId, date])
}

model Message {
  id         Int      @id @default(autoincrement())
  schoolId   Int
  senderId   Int
  receiverId Int
  content    String
  isRead     Boolean  @default(false)
  
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender     User     @relation("Sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
}

model Notice {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  authorId  Int
  title     String
  content   String
  audience  String   @default("all")
  isActive  Boolean  @default(true)
  expiresAt DateTime?
  
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  author    User      @relation("NoticeAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model FeeStructure {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  name      String
  amount    Float
  classLevel String?
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payments  Payment[]

  createdAt DateTime @default(now())
}

model Payment {
  id                Int      @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  feeStructureId    Int
  academicSessionId Int
  termId            Int
  amount            Float
  method            String
  status            String
  reference         String?  @unique
  
  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure      FeeStructure    @relation(fields: [feeStructureId], references: [id])
  term              Term            @relation(fields: [termId], references: [id])
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id])

  createdAt DateTime @default(now())
}

model MiscFee {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  name        String
  description String?
  amount      Float
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  payments    MiscFeePayment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MiscFeePayment {
  id        Int      @id @default(autoincrement())
  miscFeeId Int
  studentId Int
  amount    Float
  method    String
  reference String?  @unique
  date      DateTime @default(now())
  
  miscFee   MiscFee  @relation(fields: [miscFeeId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ExamCard {
  id                Int             @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  academicSessionId Int
  termId            Int
  cardNumber        String          
  issuedAt          DateTime        @default(now())
  
  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  term              Term            @relation(fields: [termId], references: [id], onDelete: Cascade)
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([schoolId, cardNumber])
}

model Timetable {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  classId   Int
  subjectId Int?
  dayOfWeek String
  startTime String
  endTime   String
  type      String
  isPublished Boolean @default(false)
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject   Subject? @relation(fields: [subjectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExamRepository {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  teacherId Int
  subjectId Int
  classId   Int
  termId    Int
  academicSessionId Int
  
  title     String
  fileUrl   String?
  driveLink String?
  status    String   @default("submitted")
  feedback  String?
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  term      Term     @relation(fields: [termId], references: [id], onDelete: Cascade)
  session   AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model LessonPlan {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  teacherId Int
  subjectId Int
  classId   Int
  week      Int
  topic     String
  content   String?
  fileLink  String?
  status    String   @default("PENDING")
  hodFeedback String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model LessonNote {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  teacherId Int
  subjectId Int
  classId   Int
  week      Int
  topic     String
  content   String?
  fileLink  String?
  status    String   @default("PENDING")
  hodFeedback String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
}

model Curriculum {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  subjectId Int
  classId   Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([schoolId, subjectId, classId])
}

model DepartmentResource {
  id           Int        @id @default(autoincrement())
  schoolId     Int
  departmentId Int
  uploaderId   Int
  title        String
  description  String?
  fileUrl      String
  fileType     String
  category     String     @default("OTHER")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  school      School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  uploader    User       @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
}

model Counter {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  entity    String
  lastValue Int      @default(0)
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, entity])
}

model Department {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  name      String
  headId    Int?     @unique
  lessonPlanLink String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  head   User?  @relation("DepartmentHead", fields: [headId], references: [id])
  staff  User[] @relation("DepartmentStaff")
  subjects Subject[]
  nudges Nudge[]
  resources DepartmentResource[]

  @@unique([schoolId, name])
}

model Nudge {
  id           Int        @id @default(autoincrement())
  senderId     Int
  sender       User       @relation("NudgeSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId   Int
  receiver     User       @relation("NudgeReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  type         String
  message      String?
  isRead       Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @default(now()) @updatedAt
}

model QuranTarget {
  id                Int             @id @default(autoincrement())
  schoolId          Int
  classId           Int             @default(1)
  academicSessionId Int             @default(1)
  termId            Int             @default(1)
  targetType        String          @default("memorization")
  period            String          @default("term")
  juzStart          Int?
  juzEnd            Int?
  surahStart        String?
  surahEnd          String?
  ayahStart         Int?
  ayahEnd           Int?
  pagesCount        Int?
  description       String?
  startDate         DateTime        @default(now())
  endDate           DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @default(now()) @updatedAt

  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student?        @relation(fields: [studentId], references: [id])
  studentId         Int?
  subject           Subject?        @relation(fields: [subjectId], references: [id])
  subjectId         Int?
  class             Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  term              Term            @relation(fields: [termId], references: [id], onDelete: Cascade)
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)
}

model QuranRecord {
  id                Int             @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  teacherId         Int
  date              DateTime        @default(now())
  type              String
  juz               Int?
  surah             String?
  ayahStart         Int?
  ayahEnd           Int?
  pages             Float?
  status            String
  comments          String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher           User            @relation("QuranTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  subject           Subject?        @relation(fields: [subjectId], references: [id])
  subjectId         Int?
}

model GalleryItem {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  title       String
  description String?
  imageUrl    String
  createdAt   DateTime @default(now())
  
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model NewsEvent {
  id          Int       @id @default(autoincrement())
  schoolId    Int
  title       String
  content     String
  type        String
  eventDate   DateTime?
  imageUrl    String?
  isPublished Boolean   @default(false)
  authorId    Int       @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now()) @updatedAt
  
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Alumni {
  id               Int      @id @default(autoincrement())
  schoolId         Int
  studentId        Int      @default(1) @unique
  graduationYear   Int
  currentJob       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Intervention {
  id                Int             @id @default(autoincrement())
  schoolId          Int
  studentId         Int
  termId            Int
  academicSessionId Int
  teacherId         Int
  type              String
  description       String?
  status            String          @default("active")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  school            School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student           Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  term              Term            @relation(fields: [termId], references: [id], onDelete: Cascade)
  academicSession   AcademicSession @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)
  teacher           User            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class             Class?          @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId           Int?
  subject           Subject?        @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  subjectId         Int?
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  userId    Int?
  action    String
  resource  String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
}

model Holiday {
  id        Int      @id @default(autoincrement())
  schoolId  Int
  name      String
  startDate DateTime
  endDate   DateTime
  
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model SchoolHoliday {
  id          Int      @id @default(autoincrement())
  schoolId    Int
  date        DateTime
  name        String
  type        String   @default("holiday")
  description String?
  createdAt   DateTime @default(now())

  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, date])
}

model Advert {
  id        Int      @id @default(autoincrement())
  title     String
  imageUrl  String
  targetUrl String?
  isActive  Boolean  @default(true)
  schoolId  Int?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PayrollVoucher {
  id             Int       @id @default(autoincrement())
  schoolId       Int
  staffId        Int
  month          Int
  year           Int
  netSalary      Float
  status         String    @default("PENDING")
  
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model PayrollRecord {
  id             Int       @id @default(autoincrement())
  userId         Int
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  month          Int
  year           Int
  baseSalary     Float
  bonus          Float     @default(0)
  deduction      Float     @default(0)
  netSalary      Float
  status         String    @default("PAID")
  createdAt      DateTime  @default(now())
}

model LoanRequest {
  id             Int       @id @default(autoincrement())
  userId         Int
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
